rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the user's role from the 'users' collection
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // --- Users Collection ---
    // Allow users to read their own data.
    // Allow admins to read any user's data.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || getUserRole(request.auth.uid) == 'admin');
      // Writes are restricted to server-side admin SDK (e.g., seeding)
      allow write: if false; 
    }

    // --- Products, Suppliers, Categories ---
    // These collections can be read by any authenticated user.
    // Writes (create, update, delete) are restricted to 'admin' and 'commercial' roles.
    match /(products|suppliers|categories)/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'commercial');
    }

    // --- Inventory Movements ---
    // Reads are restricted to 'admin' and 'logistics'.
    // Writes (new movements) are restricted to 'admin' and 'logistics'.
    match /inventoryMovements/{movementId} {
      allow read, create: if request.auth != null && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'logistics');
      // No updates or deletes from the client for historical data integrity
      allow update, delete: if false;
    }
    
    // --- Default deny all other access ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
